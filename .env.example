NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Payload CMS
PAYLOAD_SECRET=replace-with-at-least-32-char-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
DATABASE_URI=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_POOL_MAX=5

# Cloudflare R2 media storage
# S3_ENDPOINT should usually be https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto

# Public bucket URL. Prefer a custom domain in production, e.g. https://media.senovio.in
NEXT_PUBLIC_R2_PUBLIC_URL=
